# GitHub Personal Access Token (fine-grained)
# Required for bug report form to create GitHub issues
# Needs: issues:write permission on theroadeldorado/golf-cam-replay
GITHUB_TOKEN=your_github_token_here

# Google Analytics 4 Measurement ID
# Get this from https://analytics.google.com → Admin → Data Streams → your stream
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
